{
  "version": 2,
  "framework": "nextjs",
  "outputDirectory": ".next",
  "redirects": [
    {
      "source": "/:path*",
      "destination": "https://www.mevaclinic.com/:path*",
      "permanent": true,
      "has": [
        {
          "type": "host",
          "value": "mevaclinic.com"
        }
      ]
    }
  ]
}
